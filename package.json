{
  "name": "@verevoir/qr",
  "version": "2.0.0",
  "description": "QR code encoding engine and SVG renderers — multiple visual styles, layered output, fabrication-ready, zero runtime dependencies",
  "homepage": "https://verevoir.io",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs"
    },
    "./qrcode": {
      "types": "./dist/qrcode/index.d.ts",
      "import": "./dist/qrcode/index.js",
      "require": "./dist/qrcode/index.cjs"
    },
    "./qrcode/node": {
      "types": "./dist/qrcode/node.d.ts",
      "import": "./dist/qrcode/node.js",
      "require": "./dist/qrcode/node.cjs"
    },
    "./qrcode/web": {
      "types": "./dist/qrcode/web.d.ts",
      "import": "./dist/qrcode/web.js",
      "require": "./dist/qrcode/web.cjs"
    }
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/qr.git"
  },
  "funding": "https://buymeacoffee.com/verevoir",
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsqr": "^1.4.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
